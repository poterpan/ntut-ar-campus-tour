          <mxGeometry x="940" y="30" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e0" value="" style="html=1;rounded=0;" edge="1" parent="1" source="obs" target="act">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="210" y="40"/><mxPoint x="230" y="40"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="e1" value="" style="html=1;rounded=0;" edge="1" parent="1" source="act" target="exec">
