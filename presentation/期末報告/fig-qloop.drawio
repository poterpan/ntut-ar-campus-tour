        <mxCell id="rew" value="計算 reward（距離 shaping + 對齊 + 吃到 / 出界）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#5a4a00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="0" width="230" height="56" as="geometry"/>
