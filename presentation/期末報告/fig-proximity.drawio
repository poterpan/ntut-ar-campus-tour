<mxfile>
  <diagram id="autolayout" name="Page-1">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="walk" value="使用者於校園中行走" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1a2e4a;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="0" width="170" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="poll" value="每秒讀取相機 Geospatial pose" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf2ff;strokeColor=#6c8ebf;fontColor=#1a2e4a;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="90" y="90" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="near" value="PoiService.GetNearest 找最近 POI（Haversine）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf2ff;strokeColor=#6c8ebf;fontColor=#1a2e4a;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="0" y="170" width="230" height="54" as="geometry"/>
        </mxCell>
        <mxCell id="dec" value="距離 &lt; 30m ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#5a4a00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="110" y="260" width="150" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="show" value="導遊 NPC 於該 POI 現身解說" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#274722;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="90" y="380" width="200" height="54" as="geometry"/>
        </mxCell>
        <mxCell id="e0" value="" style="html=1;rounded=0;" edge="1" parent="1" source="walk" target="poll">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="190" y="50"/><mxPoint x="190" y="70"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="e1" value="" style="html=1;rounded=0;" edge="1" parent="1" source="poll" target="near">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="160" y="140"/><mxPoint x="160" y="160"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="e2" value="" style="html=1;rounded=0;" edge="1" parent="1" source="near" target="dec">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="170" y="230"/><mxPoint x="170" y="250"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="e3" value="是" style="html=1;rounded=0;" edge="1" parent="1" source="dec" target="show">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="190" y="340"/><mxPoint x="190" y="370"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="e4" value="否（繼續輪詢）" style="html=1;rounded=0;" edge="1" parent="1" source="dec" target="poll">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="250" y="260"/><mxPoint x="250" y="150"/></Array></mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
